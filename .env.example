# Web access
# The compose file binds to 127.0.0.1 by default, so the admin panel is local-only.
APP_PORT=9000

# Runtime
TZ=Asia/Shanghai
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
DB_PATH=/app/data/xianyu_data.db
LOG_LEVEL=INFO
DEBUG=false
RELOAD=false

# Admin account
# Change these before starting the service.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET_KEY=change-this-long-random-string
SESSION_TIMEOUT=3600
TOKEN_EXPIRE_TIME=86400

# Multi-user settings
MULTIUSER_ENABLED=true
USER_REGISTRATION_ENABLED=false
EMAIL_VERIFICATION_ENABLED=false
CAPTCHA_ENABLED=true

# Reply and delivery switches
AUTO_REPLY_ENABLED=true
AI_REPLY_ENABLED=false
AUTO_DELIVERY_ENABLED=false
AUTO_DELIVERY_TIMEOUT=30
API_CARD_TIMEOUT=10
BATCH_DATA_LOCK_TIMEOUT=5

# AI reply defaults. API keys should be configured in the web UI or local config only.
DEFAULT_AI_MODEL=qwen-plus
DEFAULT_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_REQUEST_TIMEOUT=30
AI_MAX_TOKENS=150

# Xianyu websocket settings, keep defaults unless the upstream project changes them.
WEBSOCKET_URL=wss://wss-goofish.dingtalk.com/
HEARTBEAT_INTERVAL=15
HEARTBEAT_TIMEOUT=5
TOKEN_REFRESH_INTERVAL=3600
TOKEN_RETRY_INTERVAL=300
MESSAGE_EXPIRE_TIME=300000

# Browser mode inside Docker
USE_XVFB=true
ENABLE_HEADFUL=true
ENABLE_VNC=false
DISPLAY=:99

# Resource limits
MEMORY_LIMIT=2048
CPU_LIMIT=2.0
MEMORY_RESERVATION=512
CPU_RESERVATION=0.5
